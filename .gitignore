# Build artifacts
build/
out/
dist/.commit
*.o
*.d
*.lst
*.map

# Intermediate build .elf (only in build/ or out/ dirs)
build/**/*.elf
out/**/*.elf
Source/**/build/**/*.elf
Source/**/out/**/*.elf

# IMPORTANT: SaltyNX distributes its bootstrap/core as .elf in dist/SaltySD/
# Those must NOT be ignored.
!dist/**/*.elf

# Compiled binaries (kept in repo but not in src)
Source/**/build/
Source/**/out/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.bak
*~

# devkitPro env caches
.cache/
